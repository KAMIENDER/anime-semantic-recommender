# Optional: enables LLM profile generation and reranking.
OPENAI_API_KEY=

# Set to 0 to force local heuristic mode.
ANIME_REC_USE_LLM=0

# Optional: override the local SQLite cache path.
ANIME_REC_DB=data/anime.sqlite

# Optional: identify your client when calling public anime metadata APIs.
ANIME_REC_UA=anime-semantic-recommender/0.1
